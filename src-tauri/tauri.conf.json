{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexusAI",
  "version": "0.1.0",
  "identifier": "com.nexusai.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NexusAI",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "./entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFRDI1QjFGRjIzRTRFQUIKUldTclRqN3lIMXZTbmtpNGdsWlRRdzFCMzZ3M2RYdndKNk5YZGtSWTlWNGtkWVdRbkRkU2pJbnAK",
      "endpoints": [
        "https://github.com/biellil/NexusAI/releases/latest/download/update.json"
      ]
    }
  }
}
